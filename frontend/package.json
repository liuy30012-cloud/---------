{
  "name": "library-frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "build": {
    "electronVersion": "41.1.1",
    "appId": "com.library.locator",
    "productName": "Bibliotheca",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": "nsis"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "build:win": "vue-tsc && vite build && npx electron-builder --win -c",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "split-poems": "node src/scripts/split-poems.cjs",
    "split-tang-authors": "node src/scripts/split-tang-by-author.cjs"
  },
  "dependencies": {
    "axios": "^1.6.8",
    "echarts": "^6.0.0",
    "element-plus": "^2.13.7",
    "gsap": "^3.14.2",
    "pinia": "^3.0.4",
    "vue": "^3.4.21",
    "vue-i18n": "^9.14.4",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.4",
    "@vue/test-utils": "^2.4.6",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "jsdom": "^26.1.0",
    "sass-embedded": "^1.99.0",
    "terser": "^5.46.1",
    "typescript": "^5.2.2",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^5.2.0",
    "vitest": "^2.1.9",
    "vue-tsc": "^2.0.6"
  }
}
