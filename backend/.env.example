# ========================================
# 数据库配置
# ========================================
DB_URL=jdbc:mysql://localhost:3306/library?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=your_strong_password_here_change_me

# ========================================
# JWT配置
# ========================================
# 生成强密钥的方法: openssl rand -base64 64
JWT_SECRET=your_generated_256_bit_secret_key_here_use_openssl_rand_base64_64_to_generate
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# ========================================
# 反爬虫配置
# ========================================
ANTI_CRAWLER_SECRET=your_anti_crawler_secret_key_here_change_me

# ========================================
# CORS配置
# ========================================
# 开发环境
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
# 生产环境示例
# CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ========================================
# 服务器配置
# ========================================
SERVER_PORT=8080

# ========================================
# Elasticsearch 配置
# ========================================
ES_URIS=http://localhost:9200
ES_USERNAME=elastic
ES_PASSWORD=changeme
ES_ENABLED=true

# ========================================
# 安全提示
# ========================================
# 1. 请修改所有包含 "change_me" 的值
# 2. 使用强密码（至少16个字符，包含大小写字母、数字、特殊字符）
# 3. JWT_SECRET 必须至少32字节（256位）
# 4. 不要将此文件提交到版本控制系统
# 5. 生产环境请使用更安全的密钥管理方案（如 HashiCorp Vault）
